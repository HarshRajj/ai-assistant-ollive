# Environment Variables for Ollive AI Benchmarking Arena
# -------------------------------------------------------
# Copy this file to `.env` and fill in your keys.

# OpenAI API Key — used for the Frontier tier (GPT-4o-mini)
# Can also be entered at runtime via the sidebar password field.
OPENAI_API_KEY=

# HuggingFace Token — used for the OSS tier (Qwen 2.5 Serverless Inference fallback)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# OSS Backend — "hf_space" (default, uses deployed HF Space) or "hf_inference"
OSS_BACKEND=hf_space

# HF Space URL — override if you deploy to a different Space
HF_SPACE_URL=https://HarshRajj-ollive-oss.hf.space
